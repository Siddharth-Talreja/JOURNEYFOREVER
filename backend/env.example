# ── Server ──────────────────────────────────
PORT=3001

# ── MongoDB ──────────────────────────────────
# Local:   mongodb://localhost:27017/journeyforever
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/wandercraft
MONGODB_URI=mongodb://localhost:27017/journeyforever

# ── Google Gemini ────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Frontend ─────────────────────────────────
# Origin(s) allowed by CORS (comma-separated)
CLIENT_ORIGIN=http://localhost:5500,http://127.0.0.1:5500
